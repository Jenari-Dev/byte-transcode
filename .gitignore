# Byte Transcode .gitignore

# Node config (contains user-specific paths and server URL)
node/byte_node_config.json

# Downloaded tools (large binaries)
node/tools/

# Python
__pycache__/
*.pyc
*.pyo

# Session/temp files
byte_session.json
*.log

# Server database and config (created at runtime)
server/config/
*.db

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
